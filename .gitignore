# Large source video files (raw footage, not used in production)
IMAGENES/VIDEOS/**
*.mov

# IMPORTANT: do NOT globally ignore *.mp4.
# Some deploy pipelines (including hosted Git builds) may consume .gitignore
# patterns and drop runtime media assets from the deployed filesystem.
# Keep ignores scoped to raw source folders only.

# Large deploy artifacts
*.zip
.deploy/
